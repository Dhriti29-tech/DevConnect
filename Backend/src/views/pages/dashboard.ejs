<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>DevConnect - Home</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #181825; color: #cdd6f4; font-family: sans-serif; }
    .hero { text-align: center; padding: 60px 20px 30px; }
    .hero h1 { font-size: 2.6rem; color: #cba6f7; margin-bottom: 10px; }
    .hero p  { color: #a6adc8; margin-bottom: 24px; }
    .btn { display: inline-block; padding: 10px 24px; border-radius: 8px; text-decoration: none; font-weight: bold; margin: 4px; }
    .btn-primary { background: #cba6f7; color: #1e1e2e; }
    .btn-outline { border: 2px solid #cba6f7; color: #cba6f7; }
    .posts { max-width: 700px; margin: 0 auto; padding: 20px; }
    .posts h2 { color: #cba6f7; margin-bottom: 16px; }
    .card { background: #1e1e2e; border-radius: 10px; padding: 20px; margin-bottom: 16px; }
    .card h3 { color: #89b4fa; margin-bottom: 8px; font-size: 1.1rem; }
    .card p  { color: #a6adc8; font-size: 0.95rem; line-height: 1.5; }
    .meta { font-size: 0.8rem; color: #6c7086; margin-top: 10px; }
    .empty { color: #6c7086; text-align: center; padding: 40px; }
  </style>
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="hero">
    <h1>DevConnect</h1>
    <p>A place for developers to share ideas and connect.</p>
    <% if (typeof user === 'undefined' || !user) { %>
      <a href="/register" class="btn btn-primary">Get Started</a>
      <a href="/login" class="btn btn-outline">Login</a>
    <% } else { %>
      <a href="/posts/create" class="btn btn-primary">+ Create Post</a>
    <% } %>
  </div>

  <div class="posts">
    <h2>Latest Posts</h2>
    <% if (posts.length === 0) { %>
      <p class="empty">No posts yet. Be the first to post!</p>
    <% } %>
    <% posts.forEach(post => { %>
      <a href="/posts/<%= post._id %>" style="text-decoration:none;">
        <div class="card" style="cursor:pointer;">
          <h3><%= post.title %></h3>
          <p><%= post.content.substring(0, 150) %><%= post.content.length > 150 ? '...' : '' %></p>
          <div class="meta">
            By <%= post.author?.name || 'Unknown' %> &bull;
            <%= new Date(post.createdAt).toDateString() %> &bull;
            <%= post.likes.length %> likes
          </div>
        </div>
      </a>
    <% }) %>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>
